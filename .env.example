# Copy to .env for local development. Never commit the real .env file.

# "dev" uses the OpenAI-compatible clients below; "prod" switches to Yandex Cloud
# SpeechKit + YandexGPT (requires ffmpeg on PATH and the YANDEX_* vars below).
SPRING_PROFILES_ACTIVE=dev

DB_URL=jdbc:postgresql://postgres:5432/svechka
DB_USER=svechka
DB_PASSWORD=svechka

# Any 32+ character random string. Generate with: openssl rand -base64 48
JWT_SECRET=dev-only-secret-key-change-me-please-32bytes-min

# OpenAI-compatible provider for transcription + dialogue. Point base-url/model at
# YandexGPT, GigaChat or any other RU aggregator that mirrors this API shape.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_TRANSCRIPTION_MODEL=whisper-1
AI_CHAT_MODEL=gpt-4o-mini

# Yandex Cloud AI Studio (SpeechKit STT + YandexGPT) — used on the "prod" profile only.
# Both services share the same service-account API key and folder.
YANDEX_FOLDER_ID=
YANDEX_API_KEY=

CORS_ALLOWED_ORIGINS=http://localhost:5173
